# Postgres connection string (Railway sets this automatically when you add the plugin)
DATABASE_URL=postgres://user:pass@host:5432/db
# Force TLS on the Postgres connection (auto-enabled for railway/supabase URLs)
PGSSL=0
# Postgres schema to use (default: public)
DB_SCHEMA=public

# Resend API key — without it (or a recipient) the digest email is skipped
RESEND_API_KEY=your-resend-api-key
# Digest recipient
DIGEST_EMAIL=you@example.com
# From address — must be on a Resend-verified domain; the resend.dev fallback is dev-only
FROM_EMAIL=onboarding@resend.dev
# Ops alerts (DB-down / aborted scrape) go here — the operator. Falls back to DIGEST_EMAIL.
ALERT_EMAIL=ops@example.com
# Display name used in email subjects, titles, and footers (default: "Job digest")
DIGEST_NAME=Job digest

# REQUIRED for PI enrichment (extraction, web resolution, networking intel).
# Without it enrichment silently disables — and with PI_GATE_STRICT on (the default)
# every job is then dropped from the digest. Set it in the deploy environment too.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Candidate profile: path to the gitignored profile.json (see profile.example.json) ...
PROFILE_PATH=profile.json
# ... or the same JSON inline — handy on Railway where profile.json isn't in the build
# PROFILE_JSON={"name":"...","bio":"...","interests":{},"applications":[]}

# Set to 1 on the first run to populate the DB without emailing
SEED=0
# PI gate: 1 (default) emails only jobs with a resolved PI; 0 emails everything
PI_GATE_STRICT=1
# Offline preview: write the rendered digest HTML to this file instead of sending
# DIGEST_HTML_OUT=digest.html

# Master Google Sheet sync (Apps Script web app) — optional; see scripts/sheet-sync.gs
SHEET_WEBHOOK_URL=
SHEET_SYNC_SECRET=

# test-email.ts only: recipient (required) and rows pulled per site (default 8)
TEST_TO=you@example.com
TEST_PER_SITE=8
